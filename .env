# Example environment configuration for Vite + Sanity.
# Copy this file to `.env` (which should be git-ignored) and replace the
# placeholder values below with your real configuration.

VITE_SANITY_PROJECT_ID=your-sanity-project-id
VITE_SANITY_DATASET=your-sanity-dataset
VITE_SANITY_API_VERSION=your-api-version
